root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 140

[*.{kt,kts}]
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_filename = enabled
ktlint_code_style = intellij_idea
ktlint_function_naming_ignore_when_annotated_with = Test,ParameterizedTest
# Multi-line signatures stay multi-line for readability — disable the rules that try
# to collapse them onto one line when "they fit", because the project prefers explicit
# trailing-comma style throughout.
ktlint_standard_class-signature = disabled
ktlint_standard_function-signature = disabled
ktlint_standard_function-expression-body = disabled

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
